<script src="/assets/js/axios.min.js"></script>
<script src="/assets/js/jquery.min.js"></script>

<script>
    var lang = "<%= t.lang %>";

    const set_path = async (path) => {
        const pageName = window.location.pathname.split("/page/")[1];
        const namePage = window.location.pathname.split("/")[1];
        const pathBox = $('#pathBox');
        if(pageNameSec == undefined || !pageNameSec) {
            if(namePage == "staff") {
                var response = await axios.get(`/api/department/all`, { params: { status: "active" } });
            } 
            else if (namePage == "region") {
                var responseHeader = await axios.get(`/api/region/all`, { params: { status: "active" } });
                var response = await axios.get(`/api/department/all`, { params: { status: "active" } });
            }
            else if (namePage == "news" || namePage == "meeting" || namePage == "events") {
                var responseHeader = await axios.get(`/api/news/all`, { params: { status: "active" } });
                var response = await axios.get(`/api/header/search`, { params: { status: "active", link: `/${namePage}` } });                
            }
            else if (namePage == "contacts") {
                var responseHeader = await axios.get(`/api/contacts/all`, { params: { status: "active" } });
                var response = await axios.get(`/api/header/all`, { params: { status: "active" } });
            }
            else {
                var response = await axios.get(`/api/${namePage == "sections" ? `section` : `${namePage}`}/all`, { params: { status: "active" } });
            }
            const result = response.data.data            

            if (namePage == "news" || namePage == "meeting" || namePage == "events") {    
                var gmenuID = result.map((item) => item?.gmenu); 
                var headerName = result.map((item) => item?.name);           
            
                var staffHeaderIDs = result
                    .filter(item => item?.link === `/${namePage}`)
                    .map(item => item?._id);
                var staffHeaderNames = result
                    .filter(item => item?.link === `/${namePage}`)
                    .map(item => item?.name);
            } else if (namePage == "contacts") {
                var gmenuID = result.map((item) => item?.gmenu._id); 
                var headerName = result.map((item) => item?.name);           
            
                var staffHeaderIDs = result
                    .filter(item => item?.link === `/${namePage}`)
                    .map(item => item?._id);
                var staffHeaderNames = result
                    .filter(item => item?.link === `/${namePage}`)
                    .map(item => item?.name);
            }
            else {
                var gmenuID = result.map((item) => item.header?.gmenu); 
                var headerName = result.map((item) => item.header?.name);           
            
                var staffHeaderIDs = result
                    .filter(item => item.header?.link === `/${namePage}`)
                    .map(item => item.header?._id);
                var staffHeaderNames = result
                    .filter(item => item.header?.link === `/${namePage}`)
                    .map(item => item.header?.name);
            }
            
            document.getElementById("pageHeaderName").innerHTML = `${staffHeaderNames[0][lang]}`
            const responseGmenu = await axios.get(`/api/gmenu/${gmenuID[0]}`, { params: { status: "active" } });
            const pathGmenu = responseGmenu.data.data
            
            if(path == 'full_path') {
                pathBox.append(`
                    <a class="breadcrumbs active" href="/api/gmenu/${gmenuID}">
                        ${pathGmenu.name[lang]}
                    </a>
                    <div class="breadcrumbs-separator">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24" class="breadcrumb_icon__tdM_m"><path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 7-5 5 5 5"></path>
                        </svg>
                    </div>
                    <a class="breadcrumbs" >
                        ${staffHeaderNames[0][lang]}
                    </a>
                `)
            }
            if(path == 'main') {
                pathBox.append(`
                    <a class="breadcrumbs">
                        ${headerName[lang]}
                    </a>
                `)
            }
        } 
        else {
            if(namePage == "page") {
                var response = await axios.get("/api/pages", { params: { params_name: pageName, status: "active" } });
            }
            else {
                var response = await axios.get("/api/sections", { params: { params_name: pageNameSec, status: "active" } });
            }
            const gmenuID = response.data.data.header.gmenu
            const responseGmenu = await axios.get(`/api/gmenu/${gmenuID}`, { params: { status: "active" } });
            const pathGmenu = responseGmenu.data.data
            if(path == 'full_path') {
                pathBox.append(`
                    <a class="breadcrumbs active" href="/api/gmenu/${gmenuID}">
                        ${pathGmenu.name[lang]}
                    </a>
                    <div class="breadcrumbs-separator">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24" class="breadcrumb_icon__tdM_m"><path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 7-5 5 5 5"></path>
                        </svg>
                    </div>
                    <a class="breadcrumbs" >
                        ${response.data.data.header.name[lang]}
                    </a>
                `)
            }
            if(path == 'main') {
                pathBox.append(`
                    <a class="breadcrumbs">
                        ${pathGmenu.name[lang]}
                    </a>
                `)
            }
        }
    }
</script>
<script>
    const pageName = window.location.pathname.split("/page/")[1];
    const match = window.location.pathname.match(/\/page\/([^/]+)|\/sections\/([^/]+)/);
    const pageNameSec = match ? (match[0]) : null;

    console.log(pageNameSec);
    
    
    const namePage = window.location.pathname.split('/')[1];
    set_path('full_path')
    const set_headers_datas = async (header, headerID, pageGH, staff) => {
            if (!header ) {
                console.error("Invalid data:", { header, pageGH });
                return;
            }
            const setTable = $("#rightHeaders_nav");
            await setTable.html("");

            const headerIDs = pageGH.map((item) => item.header?._id).filter(Boolean);

            const pageNames = pageGH.map((item) => item.params_name).filter(Boolean);
            console.log(pageNames);
            
            
            if(staff) {
                if(namePage == "news" || namePage == "meeting" || namePage == "events" || namePage == "contacts") {
                    var staffHeaderIDs = staff
                        .filter(item => item?.link === `/${namePage}`)
                        .map(item => item?._id);
                    var staffHeaderNames = staff
                        .filter(item => item?.link === `/${namePage}`)
                        .map(item => item?.name);
                } 
                else {
                    var staffHeaderIDs = staff
                        .filter(item => item.header?.link === `/${namePage}`)
                        .map(item => item.header?._id);
                    var staffHeaderNames = staff
                        .filter(item => item.header?.link === `/${namePage}`)
                       .map(item => item.header?.name);
                }
                header.forEach((item) => {
                    
                    const isActive = staffHeaderIDs.includes(item._id);
                    
                    const isHeaderMatched = headerIDs.includes(item._id);
                    const matchedPageName = isHeaderMatched ? pageNames[headerIDs.indexOf(item._id)] : "";
                    

                    setTable.append(`
                        ${item.name[lang] == "" ? `` : `
                            ${!item.link ? `
                               <a  href="/page/${matchedPageName}" id="pathRmenu" class="right-menu_item ${isActive ? `active` : ``}">
                                    <span class="shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24">
                                            <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 7-5 5 5 5"></path>
                                        </svg>
                                    </span>
                                    <span id="header_text">${item.name[lang]}</span>
                                
                                </a>
                               ` : `
                               <a ${item.link.startsWith('https://') ? `target="_blank"` : `` } ${isActive  ? "" : `href="${item.link ? `${item.link}` : ``}"`}  id="pathRmenu" class="right-menu_item ${isActive ? "active" : ""}">
                                    <span class="shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24">
                                            <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 7-5 5 5 5"></path>
                                        </svg>
                                    </span>
                                    <span id="header_text">${item.name[lang]}</span>
                                </a>
                           `}
                        `}
                        
                    `);
                });
            } 
            else {
                header.forEach( async (item) => {

                    if(namePage == "page") {
                        var response = await axios.get("/api/pages", { params: { params_name: pageName, status: "active" } });
                    }
                    else {
                        var response = await axios.get("/api/sections", { params: { params_name: pageNameSec, status: "active" } });
                    }
                    const headerIdOfPage = response.data.data.header._id;                    
                    const isHeaderMatched = headerIDs.includes(item._id);
                    const matchedPageName = isHeaderMatched ? pageNames[headerIDs.indexOf(item._id)] : "";
                    if(namePage == "page") {
                        setTable.append(`
                            ${item.name[lang] == "" ? ``
                            : `
                               ${!item.link ? `
                               <a ${headerIdOfPage === item._id ? "" : `href="/page/${matchedPageName}"`}  id="pathRmenu" class="right-menu_item ${headerIdOfPage === item._id ? "active" : ""}">
                                    <span class="shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24">
                                            <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 7-5 5 5 5"></path>
                                        </svg>
                                    </span>
                                    <span id="header_text">${item.name[lang]}</span>
                                </a>
                               ` : `
                               <a ${item.link.startsWith('https://') ? `target="_blank"` : `` } href="${item.link ? `${item.link}` : ``}" id="pathRmenu" class="right-menu_item ${headerIdOfPage === item._id ? "active" : ""}">
                                    <span class="shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24">
                                            <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 7-5 5 5 5"></path>
                                        </svg>
                                    </span>
                                    <span id="header_text">${item.name[lang]}</span>

                                </a>
                               `} 
                            `}
                        `);
                    }
                    else {
                        setTable.append(`
                            ${item.name[lang] == "" ? ``
                            : `
                               ${!item.link ? `
                               <a ${headerIdOfPage === item._id ? "" : `href="/page/${matchedPageName}"`}  id="pathRmenu" class="right-menu_item ${headerIdOfPage === item._id ? "active" : ""}">
                                    <span class="shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24">
                                            <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 7-5 5 5 5"></path>
                                        </svg>
                                    </span>
                                    <span id="header_text">${item.name[lang]}</span>
                                </a>
                               ` : `
                               <a ${item.link.startsWith('https://') ? `target="_blank"` : `` } href="${item.link ? `${item.link}` : ``}" id="pathRmenu" class="right-menu_item ${headerIdOfPage === item._id ? "active" : ""}">
                                    <span class="shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="none" viewBox="0 0 24 24">
                                            <path stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m15 7-5 5 5 5"></path>
                                        </svg>
                                    </span>
                                    <span id="header_text">${item.name[lang]}</span>

                                </a>
                               `} 
                            `}
                        `);
                    }

                    
                    
                });
            }
            
        };
    const set_content = async (data) => {
            document.getElementById('viewCount').innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="current"><path d="M15 12a3 3 0 1 1-5.943-.581c1.474.541 2.927-.882 2.405-2.371Q11.723 9.002 12 9a3 3 0 0 1 3 3m-2.985-7C4.446 5 0 11.551 0 11.551S4.835 19 12.015 19C19.748 19 24 11.551 24 11.551S19.709 5 12.015 5M12 17a5 5 0 1 1 0-10 5 5 0 0 1 0 10"></path></svg>
                <p>${data.views}</p>
            `
            const dataUpdate =  document.createElement('p')
                dataUpdate.setAttribute("id","updatedAt")
                dataUpdate.setAttribute('class',"content_updatedAt")
            const updateBOX = document.getElementById('updatedATDATA')
                updateBOX.appendChild(dataUpdate)
            const adjustedDate = new Date(data.createdAt);
            adjustedDate.setHours(adjustedDate.getHours() + 5);
            const formattedDate = adjustedDate.toISOString().replace("T", " ").split(".")[0];
            const updatedAtBox = document.getElementById('updatedAt').innerHTML = `<%= t.latestupdate %> : ${formattedDate}`
            const HeaderName = document.getElementById('pageHeaderName');
            if(data.name.uz || data.name.ru || data.name.eng) {
                HeaderName.innerHTML = `${data.name[lang]}`
            }else {
                HeaderName.innerHTML = `${data.header.name[lang]}`
            }

            if (data.images && Array.isArray(data.images) && data.images.length > 0) {
                const setImg = $('#imgSet');
                await setImg.html(""); // Clear previous images

                if (Array.isArray(data.images) && data.images.length > 1) {
                    const arr = data.images
                    arr.forEach((item, index) => {
                        setImg.append(`
                            <img src="${data.images[index += 0]}" alt="Image" class="imgData" style="color: transparent; max-width: 100%; margin-bottom: 1rem;">
                        `);

                    })
                } else {
                    setImg.append(`
                        <img src="${data.images[0]}" alt="Image" class="imgData" style="color: transparent; max-width: 100%;">
                    `);
                }
            }

            const result = data;
            const setTable = $("#text_area");
            await setTable.html("");        


            setTable.append(`
                ${result.textarea[lang]}
            `)
            // document.querySelectorAll("#text_area p").forEach(p => p.removeAttribute("style"));
            // document.querySelectorAll("#text_area span").forEach(p => p.removeAttribute("style"));
            // document.querySelectorAll("#text_area br").forEach(p => p.removeAttribute("style"));
            // document.querySelectorAll("#text_area a").forEach(p => p.removeAttribute("style"));
            // document.querySelectorAll("#text_area p span").forEach(p => p.removeAttribute("style")); 
            // document.querySelectorAll("#text_area p span br").forEach(p => p.removeAttribute("style"));
            // document.querySelectorAll("#text_area p span a").forEach(p => p.removeAttribute("style"));
        }
    const set_contentS = async (data) => {
        const result = data;
        
        const setTable = $("#text_area");
        await setTable.html("");
        setTable.append(`
            <div class="flex flex-col gap-5" id="content">
                
            </div>
        `)
        const content = $('#content')
        await content.html("")

        if(result.length >= 0) {
            setTable.append(`
            <div style="display: grid; justify-items: center; align-content: center; width: 100%; height: 120px">
                        <div>
                            <svg width="64" height="41" viewBox="0 0 64 41" xmlns="http://www.w3.org/2000/svg">
                                <title>No data</title>
                                <g transform="translate(0 1)" fill="none" fill-rule="evenodd">
                                    <ellipse fill="#f5f5f5" cx="32" cy="33" rx="32" ry="7"></ellipse>
                                    <g fill-rule="nonzero" stroke="#d9d9d9">
                                        <path
                                           d="M55 12.76L44.854 1.258C44.367.474 43.656 0 42.907 0H21.093c-.749 0-1.46.474-1.947 1.257L9 12.761V22h46v-9.24z">
                                        </path>
                                        <path
                                            d="M41.613 15.931c0-1.605.994-2.93 2.227-2.931H55v18.137C55 33.26 53.68 35 52.05 35h-40.1C10.32 35 9 33.259 9 31.137V13h11.16c1.233 0 2.227 1.323 2.227 2.928v.022c0 1.605 1.005 2.901 2.237 2.901h14.752c1.232 0 2.237-1.308 2.237-2.913v-.007z"
                                            fill="#fafafa"></path>
                                    </g>
                                </g>
                            </svg>
                        </div>
                        <div class="mt-2" style="color: rgba(0, 0, 0, 0.45)">No data</div>
                    </div>
                    `)
        }


        result.forEach( async (item)=> {
            content.append(`
                <a href="/section/view/${item.params_number}" class="flex items-center px-6 py-2 gap-5 h-full basis-20 link-box_box">
                    <span class="link-box_line"></span>
                    <div class="grow flex" style="gap: var(--mantine-spacing-xs); justify-content: center; flex-direction: column;">
                        <p class="uppercase only-2-lines text__m" style="padding-top: 0 !important">
                            ${item.name[lang]}
                        </p>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg" xml:space="preserve" width="24" height="24" viewBox="0 0 32 32" class="link-box_box__icon"><g fill="current"><path d="M16 0C7.163 0 0 7.163 0 16s7.163 16 16 16 16-7.164 16-16S24.836 0 16 0m0 30C8.28 30 2 23.72 2 16S8.28 1.969 16 1.969 30 8.28 30 16s-6.28 14-14 14"></path><path d="M13.808 8.271a.994.994 0 0 0-1.414 0 1.017 1.017 0 0 0 0 1.429l6.195 6.285-6.196 6.285a1.017 1.017 0 0 0 0 1.429.994.994 0 0 0 1.414 0l6.9-6.999a1.037 1.037 0 0 0 0-1.429z"></path></g></svg>
                </a>
            `)
        });
    }
    
    const get_all_datas = async () => {
        try {
            
            const pageSecSplitted = pageNameSec.split('/')[1]            
            if (pageSecSplitted == "page") {
                const response = await axios.get("/api/pages", { params: { params_name: pageName, status: "active" } });
                const pathLink = response.data.data.params_name
                set_content(response.data.data)

                
                
                const gmenuID = response.data.data.header.gmenu
                
                const responseGmenu = await axios.get(`/api/gmenu/${gmenuID}`, { params: { status: "active" } });
                const pathGmenu = responseGmenu.data.data
                
                const headerID = response.data.data.header._id
                
                const headers = await axios.get("/api/header/search", { params: { gmenu: gmenuID, status: 'active' }})
                const pagesResponses = await axios.get("/api/pages/all", { params: { status: 'active' } });
                
                await set_headers_datas(headers.data.data, headerID, pagesResponses.data.data)
            }else {
                const response = await axios.get("/api/sections", { params: { params_name: pageNameSec, status: "active" } });
                const responseSec = await axios.get("/api/section/view/search", { params: { section: response.data.data._id, status: "active" } });
                const pathLink = response.data.data
                console.log(response.data.data);              
                console.log(responseSec.data.data)

                set_contentS(responseSec.data.data)
                
                
                const gmenuID = response.data.data.header.gmenu
                
                const responseGmenu = await axios.get(`/api/gmenu/${gmenuID}`, { params: { status: "active" } });
                const pathGmenu = responseGmenu.data.data
                
                
                const headerID = response.data.data.header._id
                
                const headers = await axios.get("/api/header/search", { params: { gmenu: gmenuID, status: 'active' }})
                
                const pagesResponses = await axios.get("/api/pages/all", { params: { status: 'active' } });
                const sectionsResponse = await axios.get("/api/section/all", { params: { status: 'active' } });
