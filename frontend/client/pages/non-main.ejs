        function openMenu(id) {
            let allMenus = document.querySelectorAll("[id^='depMenu_']");
            let allBoxes = document.querySelectorAll(".boxMenu");
            let allDropdowns = document.querySelectorAll(".drop-menu");

            allMenus.forEach(menu => {
                if (menu.id !== `depMenu_${id}`) {
                    menu.classList.add("none");
                }
            });
        
            allBoxes.forEach(box => {
                if (box.getAttribute("onclick").includes(id)) {
                    box.classList.toggle("active");
                } else {
                    box.classList.remove("active");
                }
            });
        
            allDropdowns.forEach(drop => {
                if (drop.getAttribute("data-drop") === id) {
                    drop.classList.toggle("active");
                } else {
                    drop.classList.remove("active");
                }
            });
        
            let menu = document.getElementById(`depMenu_${id}`);
            if (menu) {
                menu.classList.toggle("none");
            } else {
                console.warn(`Element not found: depMenu_${id}`);
            }
        }

