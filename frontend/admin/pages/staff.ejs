    $(document).ready(function () {
        $("#siteData, #phoneData, #emailData, #timeData, #locationData, #taskModalBtn, #OutDescription").hide();
        $("#phone").on("input", function () {
            let phoneVal = $(this).val().trim();
            if (phoneVal === "") {
                $("#phoneData").hide();
            } else {
                let matchingDialCode = dialCodes.find(code => phoneVal.startsWith(code));

                if (matchingDialCode) {
                    let slicedPhone = phoneVal.slice(matchingDialCode.length);
                    $("#OutPhone").html(`(+${matchingDialCode}) ${slicedPhone}`);
                } else {
                    $("#OutPhone").html(`(+998) ${phoneVal}`);
                }

                $("#phoneData").attr("href", `tel:${phoneVal}`).show();
            }
        });
        $("#email").on("input", function () {
            let emailVal = $(this).val();
            if (emailVal.trim() === "") {
                $("#emailData").hide();
            } else {
                $("#OutEmail").html(emailVal);
                $("#emailData").attr("href", `mailto:${emailVal}`).show();
            }
        });
        $("#task_uz, #task_ru, #task_eng").on("input", function () {
            let Val = $(this).val();
            if (Val.trim() === "") {
                $("#taskModalBtn").hide();
            } else {
                $("").html();
                $("#taskModalBtn").show();
            }
        });
        $("#description_uz, #description_ru, #description_eng").on("input", function () {
            let Val = $(this).val();
            if (Val.trim() === "") {
                $("#OutDescription").hide();
            } else {
                $("").html();
                $("#OutDescription").show();
            }
        });
        $("#site").on("input", function () {
            let siteVal = $(this).val();
            if (siteVal.trim() === "") {
                $("#siteData").hide();
            } else {
                $("#OutSite").html(
                    siteVal.startsWith("http") ? siteVal : `https://${siteVal}`
                );
                $("#siteData")
                    .attr(
                        "href",
                        siteVal.startsWith("http") ? siteVal : `https://${siteVal}`
                    )
                    .show();
            }
        });
        $("#time").on("input", function () {
            let timeVal = $(this).val();
            if (timeVal.trim() === "") {
                $("#timeData").hide();
            } else {
                $("#OutTime").html(timeVal);
                $("#timeData").show();
