                                            </a>
                                            <div id="timeDataq" style="display: flex; align-items: center; gap: 0.625rem">
                                                <svg style="width: 24px; flex-shrink: 0; fill: #043b87" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                                    <path
                                                        d="M3.6 20.4C1.3 18.2 0 15.2.1 12c0-3.2 1.3-6.2 3.5-8.4C5.8 1.3 8.8 0 12 .1c3.2 0 6.2 1.3 8.4 3.5s3.5 5.3 3.5 8.4c0 3.2-1.3 6.2-3.5 8.4s-5.3 3.5-8.4 3.5c-3.2.1-6.2-1.2-8.4-3.5M2.4 12c0 5.3 4.3 9.6 9.6 9.6s9.6-4.3 9.6-9.6-4.3-9.6-9.6-9.6h-.1c-5.3.1-9.5 4.3-9.5 9.6m10.3 7.3c0-.4-.3-.7-.7-.7s-.7.3-.7.7v.9c-4-.3-7.1-3.5-7.4-7.5h.8c.4 0 .7-.3.7-.7s-.3-.7-.7-.7h-.8c.4-3.9 3.4-7 7.3-7.4v.7c0 .4.3.7.7.7s.7-.3.7-.7v-.8c4 .3 7.1 3.4 7.5 7.3h-.8c-.4 0-.7.3-.7.7s.3.7.7.7h.9c-.3 4-3.4 7.2-7.5 7.6zM7.4 7.4c-.3.3-.3.7 0 1l4.1 4.1c.1.1.3.2.5.2s.4-.1.5-.2l2.4-2.4c.3-.3.3-.7 0-1s-.7-.3-1 0L12 11 8.4 7.4c-.1-.2-.3-.2-.5-.2s-.4.1-.5.2"
                                                        class="clock_svg__st0"></path>
                                                </svg>
                                                <i style="font-size: 1rem; color: #000; max-width: 20rem">
                                                    <span id="OutTimeq">${result.data.time}</span>
                                                    <span id="OutTimeStartq">${result.data.timeStart}</span>
                                                    <span id="OutTimeEndq">${result.data.timeEnd}</span>
                                                </i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div style="display: flex; flex-direction: column;"> 
                                <label class="mt-2">Photo</label>
                                <input type="file" id="imageq" class="form-control form-control-sm" style="width: 280px" accept=".jpg, .jpeg, .png, .webp" onchange="loadFileq(event)" />
                            </div>
                        </div>
                        <div style="display: flex; flex-direction: column;" class="mt-2"> 
                            <label>Task</label>
                            <textarea id="task_uzq" value="${result.data.tasks.uz}" style="min-height: 100px; padding: 10px; font-size: 14px;" placeholder="uz"></textarea>
                            <textarea id="task_ruq" value="${result.data.tasks.ru}" class="mt-1" style="min-height: 100px; padding: 10px; font-size: 14px;" placeholder="ru"></textarea>
                            <textarea id="task_engq" value="${result.data.tasks.eng}" class="mt-1" style="min-height: 100px; padding: 10px; font-size: 14px;" placeholder="eng"></textarea>
                        </div>
                    </div>
                `);

                $(document).ready(function () {                    
                    $("#siteDataq, #phoneDataq, #emailDataq, #timeDataq, #locationDataq, #taskModalBtnq, #OutDescriptionq").hide();
                    
                    if(result.data.tasks.uz !== "" ) {
                        $("#taskModalBtnq").show()
                    }
                    const dataQ = [
                        "#siteDataq",
                        "#phoneDataq",
                        "#emailDataq",
                        "#timeDataq",
                        "#locationDataq",
                        "#OutDescriptionq"
                    ]
                    dataQ.forEach((item) => {
                        if ($(item).text().trim() !== "") {
                            $(item).show();
                        }
                    });

                    $("#phoneq").on("input", function () {
                        let phoneVal = $(this).val().trim();
                        if (phoneVal === "") {
                            $("#phoneDataq").hide();
                        } else {
                            
                            $("#phoneDataq").attr("href", `tel:${phoneVal}`).show();
                        }
                    });
                    let phoneVal = $("#phoneq").val().trim();
                    let matchingDialCode = dialCodes.find(code => phoneVal.startsWith(code));
                    if (matchingDialCode) {
                        let slicedPhone = phoneVal.slice(matchingDialCode.length);
                        $("#OutPhoneq").html(`(+${matchingDialCode}) ${slicedPhone}`);
                    } else {
                        $("#OutPhoneq").html(`(+998) ${phoneVal}`);
                    }
                    $("#emailq").on("input", function () {
                        let emailVal = $(this).val();
                        if (emailVal.trim() === "") {
                            $("#emailDataq").hide();
                        } else {
                            $("#OutEmailq").html(emailVal);
                            $("#emailDataq").attr("href", `mailto:${emailVal}`).show();
                        }
                    });
                    $("#task_uzq").on("input", function () {
                        let Val = $(this).val();
                        if (Val.trim() === "") {
                            $("#taskModalBtnq").hide();
                        } else {
                            $("#taskModalBtnq").show();
                        }
                    });
                    $("#description_uzq").on("input", function () {
                        let Val = $(this).val();
                        if (Val.trim() === "") {
                            $("#OutDescriptionq").hide();
                        } else {
                            $("#OutDescriptionq").html(Val);
                            $("#OutDescriptionq").show();
                        }
                    });
                    $("#siteq").on("input", function () {
                        let siteVal = $(this).val();
                        if (siteVal.trim() === "") {
                            $("#siteDataq").hide();
                        } else {
                            $("#OutSiteq").html(siteVal.startsWith("http") ? siteVal : `https://${siteVal}`);
                            $("#siteDataq").attr("href", siteVal.startsWith("http") ? siteVal : `https://${siteVal}`).show();
                        }
                    });
                    $("#timeq").on("input", function () {
                        let timeVal = $(this).val();
                        if (timeVal.trim() === "") {
                            $("#timeDataq").hide();
                            $("#timeStartq").val("");
                            $("#timeEndq").val("");
                        } else {
                            $("#OutTimeq").html(timeVal);
                            $("#timeDataq").show();
                        }
                    });
                    $("#locationq").on("input", function () {
                        let timeVal = $(this).val();
                        if (timeVal.trim() === "") {
                            $("#locationDataq").hide();
                        } else {
                            $("#OutLocationq").html(timeVal);
                            $("#locationDataq").show();
                        }
                    });
                    $("#timeStartq").on("input", function () {
                        let timeStartVal = $(this).val();
                        if (timeStartVal.trim() === "") {
                            $("#OutTimeStartq").hide();
                        } else {
                            $("#OutTimeStartq").html(timeStartVal).show();
                        }
                    });
                    $("#timeEndq").on("input", function () {
                        let timeEndVal = $(this).val();
                        if (timeEndVal.trim() === "") {
                            $("#OutTimeEndq").hide();
                        } else {
                            $("#OutTimeEndq").html("- " + timeEndVal ).show();
                        }
                    });
                    $("#name_uzq").on("input", function () {
                        $("#OutNameq").html($(this).val());
                    });
                });
                const selectElem = $("#timeq");
                const selectedValue = result.data.time;
                const days = [
                    { value: "", label: "Select" },
                    { value: "Monday", label: "Dushanba" },
                    { value: "Tuesday", label: "Seshanba" },
                    { value: "Wednesday", label: "Chorshanba" },
                    { value: "Thursday", label: "Payshanba" },
                    { value: "Friday", label: "Juma" },
                    { value: "Saturday", label: "Shanba" },
                    { value: "Sunday", label: "Yakshanba" },
                ];
                selectElem.html("");
                days.forEach(({ value, label }) => {
                    const isSelected = value === selectedValue ? "selected" : "";
                    selectElem.append(
                        `<option value="${value}" ${isSelected}>${label}</option>`
                    );
                });
                if(result.data.department == undefined ){} 
                else {
                    var CategoryId = result.data.department._id;
                }

                const get_all_rh = async (menu, url) => {
                    axios.get(`/api/${url}/all`, { params: { status: "active" } })
                        .then(async (res) => {
                            const data = res.data.data; // [{}, {}, {}, ...]
                            const elem = $(menu);
                            await elem.html("");
                            elem.append(`<option value="">Select</option>`);
                            data.forEach((header) => {
                                elem.append(
                                    `<option ${header._id == CategoryId ? 'selected' : ''} value="${header._id}">${header.name.uz}</option>`
                                );
                            });
                        });
                };
                get_all_rh("#headerPageq", "department");
                get_all_rh("#regionPageq", "region");
            }
        });
    };

    const updateData = (id) => {
        const header_pageq = document.getElementById("headerPageq").value;
        const regionPageq = document.getElementById("regionPageq").value;

        const name_uzq = document.getElementById("name_uzq").value;
        const name_ruq = document.getElementById("name_ruq").value;
        const name_engq = document.getElementById("name_engq").value;

        const txt_uzq = document.getElementById("description_uzq").value;
        const txt_ruq = document.getElementById("description_ruq").value;
        const txt_engq = document.getElementById("description_engq").value;

        const task_uzq = document.getElementById("task_uzq").value;
        const task_ruq = document.getElementById("task_ruq").value;
        const task_engq = document.getElementById("task_engq").value;

        const phoneq = document.getElementById("phoneq").value;
        const emailq = document.getElementById("emailq").value;
        const siteq = document.getElementById("siteq").value;
        const locationq = document.getElementById("locationq").value;

        const timeq = document.getElementById("timeq").value;
        const timeStartq = document.getElementById("timeStartq").value;
        const timeEndq = document.getElementById("timeEndq").value;
        const imageInput = document.getElementById("imageq");
        const image = imageInput?.files[0] || null;
        if (image !== null) {
            editImage(id);
        }else{}
        const tokens = window.localStorage.getItem("hTawDwdI4awd412wa");
        if (!tokens) {
            alert("You should sign-in to your profile");
            return;
        } else {
            axios.get("/api/admin/decode", { headers: { Authorization: tokens } })
                .then((res) => {
                    const data = res.data;
                    if (data.status === true) {
                        if (!header_pageq && !regionPageq) {
                            axios.put(`/api/staff/${id}`, {
                                name: { uz: name_uzq, ru: name_ruq, eng: name_engq },
                                description: { uz: txt_uzq, ru: txt_ruq, eng: txt_engq },
                                tasks: { uz: task_uzq, ru: task_ruq, eng: task_engq },
                                phone: phoneq,
                                email: emailq,
                                department: null,
                                address: null,
                                site: siteq,
                                location: locationq,
                                time: timeq,
                                timeStart: timeStartq,
                                timeEnd: timeEndq,
                            });
                        } else {
                            axios.put(`/api/staff/${id}`, {
                                name: { uz: name_uzq, ru: name_ruq, eng: name_engq },
                                description: { uz: txt_uzq, ru: txt_ruq, eng: txt_engq },
                                tasks: { uz: task_uzq, ru: task_ruq, eng: task_engq },
                                phone: phoneq,
                                email: emailq,
                                department: header_pageq || null,
                                address: regionPageq || null,
                                site: siteq,
                                location: locationq,
                                time: timeq,
                                timeStart: timeStartq,
                                timeEnd: timeEndq,
                            });
                        }
                    } else {
                        alert("Akkountga kirish kerak!");
                    }
                });
        }
    };
    const editImage = (id) => {
        const imageInput = document.getElementById("imageq");
        const image = imageInput?.files[0] || null;
        const formData = new FormData();
        formData.append("image", image);
        axios
            .put(`/api/staff/file/${id}`, formData)
            .then((response) => {
                get_all_datas("active");
                get_all_datas("archive");
            })
            .catch((error) => {
                console.error("Image Upload Error:", error);
            });
    };
</script>