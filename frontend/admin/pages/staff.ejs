<div class="main__items">
    <h1 style="text-align: center" class="mt-2 ms-13 col-md-10">Guides menu</h1>

    <div class="row col-md-10 ms-13">
        <button data-bs-toggle="offcanvas" data-bs-target="#CREATE_DATA" aria-controls="CREATE_DATA" type="button"
            class="btn col-md-1 btn-success btn-sm">
            Create
        </button>
        <button data-bs-toggle="offcanvas" data-bs-target="#ARCHIVE_DATA" aria-controls="ARCHIVE_DATA" type="button"
            class="btn col-md-1 btn-danger btn-sm ms-1">
            Archive
        </button>
    </div>

    <div class="count row col-md-10 ms-12 mt-3">
        <h4 id="count">Count:</h4>
    </div>

    <div class="news-table" style="flex-direction: column;"></div>
</div>
<!-- Create -->
<div class="offcanvas offcanvas-end" style="width: 1920px" data-bs-backdrop="static" tabindex="-1" id="CREATE_DATA"
    aria-labelledby="CREATE_DATA">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="staticBackdropLabel">Create - Guides</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body" style="display: flex; flex-direction: row; justify-content: space-evenly">
        <div class="box-left" style="width: 25%">
            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Header</label>
                <select id="headerPage" class="form-control form-control-sm"></select>
            </div>
            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Region</label>
                <select id="regionPage" class="form-control form-control-sm">
                </select>
            </div>
            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Name</label>
                <input type="text" class="form-control form-control-sm" id="name_uz" placeholder="Sarlavha..." />
                <input type="text" class="form-control form-control-sm mt-1" id="name_ru" placeholder="Загаловок..." />
                <input type="text" class="form-control form-control-sm mt-1" id="name_eng" placeholder="Heading..." />
            </div>

            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Description</label>
                <input type="text" id="description_uz" class="form-control form-control-sm" placeholder="Ma'lumot..." />
                <input type="text" id="description_ru" class="form-control form-control-sm mt-1"
                    placeholder="Информация..." />
                <input type="text" id="description_eng" class="form-control form-control-sm mt-1"
                    placeholder="Description..." />
            </div>

            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Info</label>
                <input type="number" id="phone" class="form-control form-control-sm" placeholder="PhoneNum" />
                <input type="email" id="email" class="form-control form-control-sm mt-1" placeholder="Email" />
                <input type="text" id="site" class="form-control form-control-sm mt-1" placeholder="SiteUrl" />
                <input type="text" id="location" class="form-control form-control-sm mt-1" placeholder="Location" />
            </div>

            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Time</label>
                <!-- <input type="text" id="time" class="form-control form-control-sm mt-2" placeholder="Week Date" /> -->
                <select name="time" id="time" class="form-control form-control-sm mt-1">
                    <option value="">Tanlang...</option>
                    <option value="Monday">Dushanba</option>
                    <option value="Tuesday">Seshanba</option>
                    <option value="Wednesday">Chorshanba</option>
                    <option value="Thursday">Payshanba</option>
                    <option value="Friday">Juma</option>
                    <option value="Saturday">Shanba</option>
                    <option value="Sunday">Yakshanba</option>
                </select>
                <input type="text" id="timeStart" class="form-control form-control-sm mt-1"
                    placeholder="StartTime - 07:00" />
                <input type="text" id="timeEnd" class="form-control form-control-sm mt-1"
                    placeholder="EndTime - 21:00" />
            </div>

            <button onclick="create_data()" type="button" class="btn col-md-6 mt-3 btn-success btn-sm">
                Save
            </button>
        </div>

