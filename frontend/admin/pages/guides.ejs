<div class="offcanvas offcanvas-end" style="width: 1920px" data-bs-backdrop="static" tabindex="-1" id="CREATE_DATA" aria-labelledby="CREATE_DATA">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="staticBackdropLabel">Create - Guides</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body" style="display: flex; flex-direction: row; justify-content: space-evenly">
        <div class="box-left" style="width: 25%">
            <div class="col-md-12 mt-3">
                <label style="font-size: 17px">Header</label>
                <select id="headerPage" class="form-control form-control-sm"></select>
                
            </div>
            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Name</label>
                <input type="text" class="form-control form-control-sm " id="name_uz" placeholder="Sarlavha..." />
                <input type="text" class="form-control form-control-sm mt-2" id="name_ru" placeholder="Загаловок..." />
                <input type="text" class="form-control form-control-sm mt-2" id="name_eng" placeholder="Heading..." />
            </div>           

            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Description</label>
                <input type="text" id="description_uz" class="form-control form-control-sm" placeholder="Ma'lumot..." />
                <input type="text" id="description_ru" class="form-control form-control-sm mt-2" placeholder="Информация..." />
                <input type="text" id="description_eng" class="form-control form-control-sm mt-2" placeholder="Description..." />
            </div>

            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Info</label>
                <input type="number" id="phone" class="form-control form-control-sm" placeholder="PhoneNum" />
                <input type="email" id="email" class="form-control form-control-sm mt-2" placeholder="Email" />
                <input type="text" id="site" value="https://" class="form-control form-control-sm mt-2" placeholder="SiteUrl" />
            </div>

            <div class="col-md-12 mt-2">
                <label style="font-size: 17px">Time</label>
                <!-- <input type="text" id="time" class="form-control form-control-sm mt-2" placeholder="Week Date" /> -->
                <select name="time" id="time" class="form-control form-control-sm mt-2">
                    <option value="">Tanlang...</option>
                    <option value="Monday">Dushanba</option>
                    <option value="Tuesday">Seshanba</option>
                    <option value="Wednesday">Chorshanba</option>
                    <option value="Thursday">Payshanba</option>
                    <option value="Friday">Juma</option>
                    <option value="Saturday">Shanba</option>
                    <option value="Sunday">Yakshanba</option>
                </select>
                <input type="text" id="timeStart" class="form-control form-control-sm mt-2" placeholder="StartTime - 07:00" />
                <input type="text" id="timeEnd" class="form-control form-control-sm mt-2" placeholder="EndTime - 21:00" />
            </div>  

            <div class="col-md-12 mt-3">
                <label style="font-size: 17px">Params Name</label>
                <input type="text" id="paramsName" class="form-control form-control-sm" placeholder="Optional"/>
            </div>

            <button onclick="create_data()" type="button" class="btn col-md-6 mt-3 btn-success btn-sm">
                Save
