                                            <div style="display: flex; align-items: center; gap: .625rem;"> 
                                                <svg style="width: 24px; flex-shrink: 0; fill: #043b87;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M3.6 20.4C1.3 18.2 0 15.2.1 12c0-3.2 1.3-6.2 3.5-8.4C5.8 1.3 8.8 0 12 .1c3.2 0 6.2 1.3 8.4 3.5s3.5 5.3 3.5 8.4c0 3.2-1.3 6.2-3.5 8.4s-5.3 3.5-8.4 3.5c-3.2.1-6.2-1.2-8.4-3.5M2.4 12c0 5.3 4.3 9.6 9.6 9.6s9.6-4.3 9.6-9.6-4.3-9.6-9.6-9.6h-.1c-5.3.1-9.5 4.3-9.5 9.6m10.3 7.3c0-.4-.3-.7-.7-.7s-.7.3-.7.7v.9c-4-.3-7.1-3.5-7.4-7.5h.8c.4 0 .7-.3.7-.7s-.3-.7-.7-.7h-.8c.4-3.9 3.4-7 7.3-7.4v.7c0 .4.3.7.7.7s.7-.3.7-.7v-.8c4 .3 7.1 3.4 7.5 7.3h-.8c-.4 0-.7.3-.7.7s.3.7.7.7h.9c-.3 4-3.4 7.2-7.5 7.6zM7.4 7.4c-.3.3-.3.7 0 1l4.1 4.1c.1.1.3.2.5.2s.4-.1.5-.2l2.4-2.4c.3-.3.3-.7 0-1s-.7-.3-1 0L12 11 8.4 7.4c-.1-.2-.3-.2-.5-.2s-.4.1-.5.2" class="clock_svg__st0"></path></svg>
                                                <i style="font-size: 1rem; color: #000; max-width: 20rem;" >
