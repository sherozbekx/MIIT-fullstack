    const updateData = (id) => {

        const header_page = document.getElementById("headerPageq").value.trim();      

        const name_uz = document.getElementById("name_uzq").value.trim();
        const name_ru = document.getElementById("name_ruq").value.trim();
        const name_eng = document.getElementById("name_engq").value.trim();

        const txt_uz = document.getElementById("description_uzq").value.trim();
        const txt_ru = document.getElementById("description_ruq").value.trim();
        const txt_eng = document.getElementById("description_engq").value.trim();

        const phone = document.getElementById("phoneq").value.trim();
        const email = document.getElementById("emailq").value.trim();
        const site = document.getElementById("siteq").value.trim();

        const time = document.getElementById("timeq").value.trim();
        const timeStart = document.getElementById("timeStartq").value.trim();
        const timeEnd = document.getElementById("timeEndq").value.trim();

        const params_name = document.getElementById("paramsNameq").value.trim();
        
        const imageInput = document.getElementById("imageq");

        const image = imageInput?.files[0] || null;

        if (image !== null) {
            editImage(id);            
        }

        const tokens = window.localStorage.getItem("hTawDwdI4awd412wa");
        if (!tokens) {
            alert("You should sign-in to your profile");
            return;
        }
        else {
            axios.get("/api/admin/decode", { headers: { Authorization: tokens } }).then((res) => {
                const data = res.data;
                if (data.status === true) {
                
                    axios.put(`/api/guides/${id}`, {
                        name: { uz: name_uz, ru: name_ru, eng: name_eng },
                        description: { uz: txt_uz, ru: txt_ru, eng: txt_eng },
                        phone: phone,
                        email: email,
                        header: header_page,
                        site: site,
                        time: time,
                        timeStart: timeStart,
                        timeEnd: timeEnd,
                        params_name: params_name,
                    })
                        .then(response => response.data)
                        .catch(error => console.error("Error updating news:", error));
                } else {
                    alert("Akkountga kirish kerak!");
                }
            });
        }
    }
    const editImage = (id) => {
        const imageInput = document.getElementById('imageq'); 
        const image = imageInput?.files[0] || null;
        const formData = new FormData();
        formData.append("image", image);
        axios.put(`/api/guides/file/${id}`, formData)
            .then((response) => {
                get_all_datas("active");
                get_all_datas("archive");
            })
            .catch(error => {
                console.error("Image Upload Error:", error);
            });
    };
</script>