                    });
                    $("#timeq").on("input", function () {
                        $("#OutTimeq").html($(this).val());
                    });
                    $("#timeStartq").on("input", function () {
                        $("#OutTimeStartq").html($(this).val());
                    });
                    $("#timeEndq").on("input", function () {
                        $("#OutTimeEndq").html($(this).val());
                    });
