<script>

    const get_all_header = async (menu) => {
        axios.get("/api/header/all", { params: { status: "active" } }).then(async (res) => {
            const data = res.data.data; // [{}, {}, {}, ...]
            const elem = $(menu);
            await elem.html('')
            elem.append(``)
            data.forEach((header) => {
                elem.append(`<option value="${header._id}">${header.name.uz}</option>`)
            });
            
        })
    }
    get_all_header('#headerPage')

    const loadFile = function(event) {
        // }
        var outputt = document.getElementById('outputt');
        outputt.src = URL.createObjectURL(event.target.files[0]);
        outputt.onload = function() {
          URL.revokeObjectURL(outputt.src) // free memory
        }
    };

    const loadFileq = function(event) {
        var outputq = document.getElementById('outputtq');
        outputq.src = URL.createObjectURL(event.target.files[0]);
        outputq.onload = function() {
          URL.revokeObjectURL(outputq.src) // free memory
        }
    }; 

    create_data = () => {

        const header_page = document.getElementById("headerPage").value;      

        const name_uz = document.getElementById("name_uz").value;
        const name_ru = document.getElementById("name_ru").value;
        const name_eng = document.getElementById("name_eng").value;

        const txt_uz = document.getElementById("description_uz").value;
        const txt_ru = document.getElementById("description_ru").value;
        const txt_eng = document.getElementById("description_eng").value;

        const phone = document.getElementById("phone").value;
        const email = document.getElementById("email").value;
        const site = document.getElementById("site").value;

        const time = document.getElementById("time").value;
        const timeStart = document.getElementById("timeStart").value;
        const timeEnd = document.getElementById("timeEnd").value;

        const params_name = document.getElementById("paramsName").value;

        const image = document.getElementById("image").files;

        const tokens = window.localStorage.getItem("hTawDwdI4awd412wa");
        if (!tokens) {
            alert("You should sign-in to your profile");
            return;
        }
        else {
            axios.get("/api/admin/decode", { headers: { Authorization: tokens } }).then((res) => {
                const data = res.data;
                if (data.status === true) {


                    const forms = new FormData();

                    forms.append("name.uz", name_uz);
                    forms.append("name.ru", name_ru);
                    forms.append("name.eng", name_eng);
                    forms.append("description.uz", txt_uz);
                    forms.append("description.ru", txt_ru);
                    forms.append("description.eng", txt_eng);
                    forms.append("time", time);
                    forms.append("timeStart", timeStart);
                    forms.append("timeEnd", timeEnd);
                    forms.append("phone", phone);
                    forms.append("email", email);
                    forms.append("site", site);
                    forms.append("params_name", params_name);

                    if (image.length > 0) {
                        forms.append("image", image[0]);
                    } else {
                        alert("Please upload a main image.");
                        return;
                    }
                    forms.append("header", header_page);

                    axios.post("/api/guides/create", forms, {
                        headers: { "Content-Type": "multipart/form-data" },
                    })
                    .then((res) => {
                        const responseData = res.data;
                        if (responseData.status) {
                            alert("News created successfully!");
                        } else {
                            console.log(responseData);
                            console.log(header_page);
                            
                        }
                    })
                    .catch((err) => {
                        console.error("Error:", err);
                        alert("Server error. Try again later.");
                    });
                } else {
                    alert("Akkountga kirish kerak!");
                }
            });
        }
    }
    
