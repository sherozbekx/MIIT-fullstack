                    { value: "Wednesday", label: "Chorshanba" },
                    { value: "Thursday", label: "Payshanba" },
                    { value: "Friday", label: "Juma" },
                    { value: "Saturday", label: "Shanba" },
                    { value: "Sunday", label: "Yakshanba" }
                ];
                selectElem.html('');

                days.forEach(({ value, label }) => {
                    const isSelected = value === selectedValue ? 'selected' : '';
                    selectElem.append(`<option value="${value}" ${isSelected}>${label}</option>`);
                });

                const CategoryId = result.data.header._id;
                axios.get("/api/header/all", { params: { status: 'active' } }).then(async (res) => {
                    const data = res.data.data; // [{}, {}, {}, ...]
                    const elem = $('#headerPageq');
                    await elem.html('')
                    data.forEach((header) => {
                        elem.append(`<option ${header._id == CategoryId ? 'selected' : ''} value="${header._id}">${header.name.uz}</option>`)
